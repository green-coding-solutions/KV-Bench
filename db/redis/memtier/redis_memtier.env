# memtier_benchmark config for Redis (KV-Bench). Sourced by the memtier scenario.
# HOST/PORT/PROTOCOL are store-specific; everything below the divider is a
# fairness knob and is byte-identical across every store (check_repo.py enforces).
MEMTIER_HOST=redis_container
MEMTIER_PORT=6379
MEMTIER_PROTOCOL=redis
# --- Fairness knobs (identical across all stores) ---
MEMTIER_CLIENTS=50
MEMTIER_THREADS=4
MEMTIER_TEST_TIME=60
MEMTIER_RATIO=1:10
MEMTIER_DATA_SIZE=100
MEMTIER_KEY_MAX=1000000
